{
  "expo": {
    "name": "LinguaBoost",
    "slug": "linguaboost",
    "scheme": "com.ptit.linguaboost",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ptit.linguaboost",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        },
        "CFBundleURLTypes": [
          {
            "CFBundleTypeRole": "Editor",
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.35790031845-86alfa4bq4t4pmp9ajkqbohnmi7j88lf"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F1A"
      },
      "package": "com.ptit.linguaboost",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "extra": {
      "apiUrlWeb": "http://172.20.10.4:8080/api",
      "apiUrlAndroid": "http://172.20.10.4:8080/api",
      "eas": {
        "projectId": "fd87ffc3-d9ac-4601-bcea-5e24efc67f78"
      }
    },
    "plugins": [
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      "expo-asset",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosClientId": "35790031845-86alfa4bq4t4pmp9ajkqbohnmi7j88lf.apps.googleusercontent.com",
          "iosUrlScheme": "com.googleusercontent.apps.35790031845-86alfa4bq4t4pmp9ajkqbohnmi7j88lf"
        }
      ],
      "expo-audio",
      "expo-video"
    ],
    "owner": "darkgodwind"
  }
}